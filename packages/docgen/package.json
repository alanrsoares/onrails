{
  "name": "@onrails/docgen",
  "version": "0.0.0",
  "private": true,
  "description": "Internal docs generators for the onrails docs site — API reference (TS AST → MDX) and snippet extraction (region → twoslash).",
  "license": "MIT",
  "author": "Alan R. Soares",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./snippets": "./src/snippets.ts",
    "./api": "./src/api/generate.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun typecheck && bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  }
}
