{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "packages/**/src/**/*.{ts,js}",
      "packages/**/test/**/*.ts",
      "packages/**/tsup.config.ts",
      "tsup.base.ts",
      "commitlint.config.cjs",
      "!packages/biome-plugin/test/fixtures",
      "!**/dist"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveLinesPerFunction": {
          "level": "warn",
          "options": { "maxLines": 50 }
        }
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noTsIgnore": "error"
      },
      "style": {
        "noNonNullAssertion": "error",
        "useImportType": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "overrides": [
    {
      "includes": ["**/*.spec.ts"],
      "linter": {
        "rules": {
          "suspicious": { "noExplicitAny": "off" }
        }
      }
    },
    {
      "includes": [
        "packages/**/src/**",
        "!packages/result/**",
        "!packages/biome-plugin/**",
        "!**/*.spec.ts"
      ],
      "plugins": [
        "./packages/biome-plugin/rules/no-promise-result.grit",
        "./packages/biome-plugin/rules/no-unsafe-unwrap.grit",
        "./packages/biome-plugin/rules/no-deprecated-synonyms.grit"
      ]
    }
  ]
}
