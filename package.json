{
  "name": "onrails",
  "private": true,
  "type": "module",
  "description": "Tagged Result / ResultAsync + railway-oriented utilities for TypeScript",
  "license": "MIT",
  "author": "Alan R. Soares",
  "homepage": "https://github.com/alanrsoares/onrails#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alanrsoares/onrails.git"
  },
  "bugs": {
    "url": "https://github.com/alanrsoares/onrails/issues"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "bun": ">=1.0"
  },
  "scripts": {
    "typecheck": "bun run --filter '@onrails/*' typecheck",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write . --error-on-warnings",
    "format": "biome format --write .",
    "test": "bun run --filter '@onrails/*' test",
    "check:loc": "bun run scripts/check-loc.ts",
    "check": "bun run check:loc && bun run lint && bun run typecheck && bun run test",
    "docs": "bun run --filter '@onrails/docs' dev",
    "docs:build": "bun run --filter '@onrails/docs' build",
    "docs:generate": "bun run scripts/generate-api-docs.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^19.6.0",
    "@onrails/docgen": "workspace:*",
    "@commitlint/config-conventional": "^19.6.0",
    "@tanstack/intent": "^0.0.44",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
