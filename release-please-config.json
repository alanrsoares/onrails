{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "include-component-in-tag": true,
  "include-v-in-tag": true,
  "separate-pull-requests": false,
  "packages": {
    "packages/result": {
      "package-name": "@onrails/result",
      "component": "result",
      "changelog-path": "CHANGELOG.md",
      "release-as": "0.1.0"
    },
    "packages/maybe": {
      "package-name": "@onrails/maybe",
      "component": "maybe",
      "changelog-path": "CHANGELOG.md",
      "release-as": "0.1.0"
    },
    "packages/pattern": {
      "package-name": "@onrails/pattern",
      "component": "pattern",
      "changelog-path": "CHANGELOG.md",
      "release-as": "0.1.0"
    },
    "packages/codemod": {
      "package-name": "@onrails/codemod",
      "component": "codemod",
      "changelog-path": "CHANGELOG.md",
      "release-as": "0.1.0"
    },
    "packages/eslint-plugin": {
      "package-name": "@onrails/eslint-plugin",
      "component": "eslint-plugin",
      "changelog-path": "CHANGELOG.md",
      "release-as": "0.1.0"
    },
    "packages/biome-plugin": {
      "package-name": "@onrails/biome-plugin",
      "component": "biome-plugin",
      "changelog-path": "CHANGELOG.md",
      "release-as": "0.1.0"
    }
  },
  "plugins": ["node-workspace"]
}
